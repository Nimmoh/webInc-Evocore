# Copy this to .env and fill in real values.
PORT=5000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# Initial admin account (only used when the admin_users table is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123


# ──────────────────────────────────────────
# Email / SMTP Configuration
# ──────────────────────────────────────────

# SMTP server hostname (from your cPanel host, e.g. mail.yourdomain.com)
MAIL_HOST=mail.yourdomain.com

# SMTP port — 465 for SSL, 587 for TLS (recommended), 25 is usually blocked
MAIL_PORT=587

# Encryption type — 'ssl' or 'tls'
MAIL_ENCRYPTION=tls

# Full email address used to authenticate with the SMTP server
MAIL_USERNAME=no-reply@yourdomain.com

# Email account password (set in cPanel > Email Accounts)
MAIL_PASSWORD=your-email-password-here

# Address that appears in the "From" field
MAIL_FROM_ADDRESS=no-reply@yourdomain.com

# Name that appears alongside the From address
MAIL_FROM_NAME=Evocore Tech